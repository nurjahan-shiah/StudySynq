# ── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@db:5432/studysync
SECRET_KEY=replace-with-a-long-random-secret
DELTA_LAKE_PATH=/data/delta-lake

# ── Supabase storage (US-D.1) ───────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key                     # safe for the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key # server-only: storage cleanup
SUPABASE_BUCKET=resources

# ── AI features (Groq) ──────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ── Data pipeline (US-F.3 / US-F.4) ────────────────────────────────────────
# Re-run ETL + recommender every N minutes; 0 = run once and exit.
ETL_INTERVAL_MINUTES=15
